---
import { useTranslations } from "../../i18n";
import { SITE } from "../../consts";

interface Props {
  lang?: "en" | "es";
}
const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="bg-surface-container dark:bg-slate-900 border-t border-border-subtle/20 dark:border-slate-800">
  <div class="max-w-7xl mx-auto px-8 py-12 flex flex-col md:flex-row justify-between items-center gap-6">
    <!-- Brand -->
    <div class="flex flex-col items-center md:items-start gap-1">
      <div class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" class="text-primary fill-current">
          <polygon points="12,2 22,22 2,22" />
        </svg>
        <span class="font-headline font-bold text-on-surface dark:text-slate-100 text-sm">{SITE.name}</span>
      </div>
      <p class="font-mono text-[10px] tracking-widest uppercase text-secondary dark:text-slate-500">
        © {year} · {t.footer.built}
      </p>
    </div>

    <!-- Social links -->
    <div class="flex gap-8">
      <a href={SITE.github} target="_blank" rel="noopener noreferrer" class="footer-link">GitHub</a>
      <a href={SITE.linkedin} target="_blank" rel="noopener noreferrer" class="footer-link">LinkedIn</a>
      <a href={`mailto:${SITE.email}`} class="footer-link">Email</a>
    </div>
  </div>
</footer>

<style>
  .footer-link {
    @apply font-mono text-xs tracking-widest uppercase text-secondary dark:text-slate-500 hover:text-primary dark:hover:text-primary-dim transition-colors;
  }
</style>
