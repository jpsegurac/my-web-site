---
import { useTranslations, getAlternateLocale } from "../../i18n";
import { SITE } from "../../consts";

interface Props {
  lang?: "en" | "es";
}
const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
const altLang = getAlternateLocale(lang);
const altPath = lang === "en" ? "/es" : "/";
---

<nav
  class="fixed top-0 left-0 w-full z-50 bg-surface/80 dark:bg-slate-950/80 backdrop-blur-xl border-b border-border-subtle/20 dark:border-slate-800/50"
>
  <div class="flex justify-between items-center w-full px-8 h-20 max-w-7xl mx-auto">
    <!-- Logo -->
    <a href={lang === "en" ? "/" : "/es"} class="flex items-center gap-3 group">
      <svg width="24" height="24" viewBox="0 0 24 24" class="text-primary fill-current">
        <polygon points="12,2 22,22 2,22" />
      </svg>
      <span class="font-headline font-bold text-on-surface dark:text-slate-100 tracking-tight text-lg">
        {SITE.name}
      </span>
    </a>

    <!-- Nav Links -->
    <div class="hidden md:flex items-center gap-8">
      <a href="#about" class="nav-link">{t.nav.about}</a>
      <a href="#experience" class="nav-link">{t.nav.experience}</a>
      <a href="#projects" class="nav-link">{t.nav.projects}</a>
      <a href="#blog" class="nav-link">{t.nav.blog}</a>
    </div>

    <!-- Right controls -->
    <div class="flex items-center gap-4">
      <!-- Lang switcher -->
      <a
        href={altPath}
        class="font-mono text-xs font-bold uppercase tracking-widest text-secondary dark:text-slate-400 hover:text-primary transition-colors"
      >
        {lang.toUpperCase()} / {altLang.toUpperCase()}
      </a>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="w-8 h-8 flex items-center justify-center text-secondary dark:text-slate-400 hover:text-primary transition-colors"
      >
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden dark:block">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="block dark:hidden">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden text-on-surface dark:text-slate-100" aria-label="Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border-subtle/20 dark:border-slate-800">
    <div class="flex flex-col px-8 py-4 gap-4">
      <a href="#about" class="nav-link">{t.nav.about}</a>
      <a href="#experience" class="nav-link">{t.nav.experience}</a>
      <a href="#projects" class="nav-link">{t.nav.projects}</a>
      <a href="#blog" class="nav-link">{t.nav.blog}</a>
    </div>
  </div>
</nav>

<style>
  .nav-link {
    @apply font-label text-sm font-bold uppercase tracking-widest text-secondary dark:text-slate-400 hover:text-primary dark:hover:text-primary-dim transition-colors;
  }
</style>

<script>
  // Theme toggle
  const btn = document.getElementById("theme-toggle");
  btn?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  });

  // Mobile menu
  const mobileBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  mobileBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => mobileMenu.classList.add("hidden"));
  });
</script>
