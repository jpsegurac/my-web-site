---
import { useTranslations } from "../../i18n";
interface Props { lang?: "en" | "es" }
const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative min-h-screen flex items-center pt-20 overflow-hidden dot-grid">
  <div class="max-w-7xl mx-auto px-8 py-24 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center w-full">

    <!-- Left: Text -->
    <div class="lg:col-span-7 z-10">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-surface-container dark:bg-slate-800 px-3 py-1 mb-8">
        <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
        <span class="font-mono text-xs font-bold uppercase tracking-widest text-secondary dark:text-slate-400">
          {t.hero.badge}
        </span>
      </div>

      <!-- Headline -->
      <h1 class="text-6xl md:text-7xl lg:text-8xl font-headline font-black leading-none tracking-tighter mb-8 text-on-surface dark:text-slate-50">
        {t.hero.headline1}<br />
        <span class="relative inline-block">
          <span class="relative z-10 text-primary">{t.hero.headline2}</span>
          <span class="absolute inset-0 bg-primary/10 -skew-x-3"></span>
        </span><br />
        {t.hero.headline3}
      </h1>

      <!-- Subtitle -->
      <p class="font-mono text-base text-secondary dark:text-slate-400 tracking-wide mb-12">
        {t.hero.subtitle}
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4">
        <a
          href="#projects"
          class="bg-primary text-white px-10 py-4 font-label font-bold uppercase tracking-widest text-sm hover:bg-primary-light transition-colors"
        >
          {t.hero.cta_projects}
        </a>
        <a
          href="#blog"
          class="border-2 border-border-subtle dark:border-slate-600 text-on-surface dark:text-slate-100 px-10 py-4 font-label font-bold uppercase tracking-widest text-sm hover:bg-surface-container dark:hover:bg-slate-800 transition-colors"
        >
          {t.hero.cta_blog}
        </a>
      </div>
    </div>

    <!-- Right: Geometric illustration -->
    <div class="lg:col-span-5 relative flex items-center justify-center">
      <div class="relative w-full max-w-md aspect-square">
        <!-- Background square -->
        <div class="absolute inset-0 border border-border-subtle/30 dark:border-slate-700/50 bg-surface-container/30 dark:bg-slate-800/30"></div>

        <!-- Geometric SVG decoration -->
        <svg
          class="absolute inset-0 w-full h-full"
          viewBox="0 0 400 400"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <!-- Large hexagon outline -->
          <polygon
            points="200,40 340,120 340,280 200,360 60,280 60,120"
            stroke="#4648d4"
            stroke-width="1"
            fill="none"
            opacity="0.3"
          />
          <!-- Inner hexagon filled -->
          <polygon
            points="200,90 305,150 305,250 200,310 95,250 95,150"
            stroke="#4648d4"
            stroke-width="1.5"
            fill="#4648d4"
            opacity="0.08"
          />
          <!-- Triangle 1 -->
          <polygon
            points="200,60 270,180 130,180"
            stroke="#4648d4"
            stroke-width="1.5"
            fill="#4648d4"
            opacity="0.15"
          />
          <!-- Triangle 2 (inverted, lower) -->
          <polygon
            points="200,340 130,220 270,220"
            stroke="#6063ee"
            stroke-width="1"
            fill="none"
            opacity="0.4"
          />
          <!-- Diamond center -->
          <polygon
            points="200,155 230,200 200,245 170,200"
            fill="#4648d4"
            opacity="0.9"
          />
          <!-- Corner accent marks -->
          <line x1="30" y1="30" x2="70" y2="30" stroke="#c7c4d7" stroke-width="1" opacity="0.6"/>
          <line x1="30" y1="30" x2="30" y2="70" stroke="#c7c4d7" stroke-width="1" opacity="0.6"/>
          <line x1="370" y1="30" x2="330" y2="30" stroke="#c7c4d7" stroke-width="1" opacity="0.6"/>
          <line x1="370" y1="30" x2="370" y2="70" stroke="#c7c4d7" stroke-width="1" opacity="0.6"/>
          <line x1="30" y1="370" x2="70" y2="370" stroke="#c7c4d7" stroke-width="1" opacity="0.6"/>
          <line x1="30" y1="370" x2="30" y2="330" stroke="#c7c4d7" stroke-width="1" opacity="0.6"/>
          <line x1="370" y1="370" x2="330" y2="370" stroke="#c7c4d7" stroke-width="1" opacity="0.6"/>
          <line x1="370" y1="370" x2="370" y2="330" stroke="#c7c4d7" stroke-width="1" opacity="0.6"/>
          <!-- Small decorative triangles -->
          <polygon points="350,60 370,90 330,90" fill="#4648d4" opacity="0.3"/>
          <polygon points="50,310 30,280 70,280" fill="#6063ee" opacity="0.2"/>
        </svg>

        <!-- Floating label -->
        <div class="absolute bottom-4 left-4 bg-surface dark:bg-slate-900 border border-border-subtle/30 dark:border-slate-700 px-3 py-2">
          <span class="font-mono text-[10px] uppercase tracking-widest text-secondary dark:text-slate-500">
            v2.0 · Full-Stack
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Diagonal bottom divider -->
  <div class="absolute bottom-0 left-0 right-0 h-16 bg-surface-low dark:bg-slate-900/50"
    style="clip-path: polygon(0 100%, 100% 0, 100% 100%)"></div>
</section>
