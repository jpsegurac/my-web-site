---
import { getCollection } from "astro:content";
import { useTranslations } from "../../i18n";

interface Props { lang?: "en" | "es" }
const { lang = "en" } = Astro.props;
const t = useTranslations(lang);

const allPosts = await getCollection("blog", ({ data }) => data.lang === lang);
const sorted = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = sorted.find((p) => p.data.featured) ?? sorted[0];
const posts = sorted.filter((p) => p !== featured).slice(0, 4);
---

<section id="blog" class="py-24 px-8 bg-surface-low dark:bg-slate-900 dot-grid">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-16 flex items-center gap-4">
      <div class="w-12 h-12 bg-primary flex items-center justify-center"
        style="clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><rect x="2" y="3" width="20" height="14" rx="0" ry="0"/><line x1="8" y1="21" x2="16" y2="21" stroke="white" stroke-width="2"/><line x1="12" y1="17" x2="12" y2="21" stroke="white" stroke-width="2"/></svg>
      </div>
      <h2 class="text-5xl md:text-6xl font-headline font-black text-on-surface dark:text-slate-50 tracking-tighter">
        {t.blog.title}
      </h2>
    </div>

    <!-- Featured post -->
    {featured && (
      <div class="group relative bg-white dark:bg-slate-800 border-l-8 border-primary flex flex-col md:flex-row shadow-[0_20px_40px_rgba(15,23,42,0.06)] dark:shadow-none mb-16">
        <div class="w-full md:w-1/2 h-64 md:h-auto bg-surface-container dark:bg-slate-700 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-primary to-slate-800 opacity-80"></div>
          <!-- Geometric decoration on featured image -->
          <svg class="absolute inset-0 w-full h-full opacity-20" viewBox="0 0 400 300" fill="none">
            <polygon points="200,20 380,280 20,280" stroke="white" stroke-width="1" fill="none"/>
            <polygon points="200,60 340,260 60,260" fill="white" fill-opacity="0.1"/>
            <polygon points="200,100 300,240 100,240" stroke="white" stroke-width="0.5" fill="none"/>
          </svg>
          <div class="absolute top-4 left-4">
            <span class="bg-primary text-white font-label px-6 py-1 text-xs tracking-widest uppercase clip-tag">
              {t.blog.featured}
            </span>
          </div>
        </div>
        <div class="w-full md:w-1/2 p-10 flex flex-col justify-center">
          <div class="flex items-center gap-4 mb-4 text-secondary dark:text-slate-400 font-mono text-xs tracking-widest uppercase">
            <span>{featured.data.pubDate.toLocaleDateString(lang === "es" ? "es-ES" : "en-US", { year:"numeric", month:"short", day:"numeric" })}</span>
            <span class="w-1 h-1 bg-border-subtle dark:bg-slate-600"></span>
            <span>{featured.data.readTime} {t.blog.min_read}</span>
          </div>
          <h3 class="text-3xl font-headline font-bold text-on-surface dark:text-slate-50 tracking-tight mb-4 leading-tight">
            {featured.data.title}
          </h3>
          <p class="text-secondary dark:text-slate-400 mb-8 line-clamp-3 font-body">
            {featured.data.description}
          </p>
          <div class="flex items-center justify-between">
            <div class="flex gap-2">
              <span class="bg-surface-container dark:bg-slate-700 text-secondary dark:text-slate-400 px-4 py-1 text-xs font-label uppercase clip-tag">
                {featured.data.category}
              </span>
            </div>
            <a href={`/${lang === "es" ? "es/" : ""}blog/${featured.slug}`}
              class="text-primary font-bold text-sm flex items-center gap-2 group-hover:gap-4 transition-all uppercase tracking-widest">
              {t.blog.read_more}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
      </div>
    )}

    <!-- Post grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {posts.map((post) => (
        <article class="bg-white dark:bg-slate-800 border-l-4 border-primary p-8 flex flex-col justify-between hover:shadow-[0_10px_30px_rgba(70,72,212,0.1)] transition-all duration-300">
          <div>
            <div class="flex justify-between items-start mb-6">
              <span class="bg-surface-container dark:bg-slate-700 text-secondary dark:text-slate-400 font-label px-4 py-1 text-xs uppercase clip-tag">
                {post.data.category}
              </span>
              <span class="font-mono text-xs text-secondary dark:text-slate-500 uppercase">
                {post.data.pubDate.toLocaleDateString(lang === "es" ? "es-ES" : "en-US", { month:"short", day:"numeric", year:"numeric" })}
              </span>
            </div>
            <h3 class="text-xl font-headline font-bold text-on-surface dark:text-slate-50 tracking-tight mb-4">
              {post.data.title}
            </h3>
            <p class="text-secondary dark:text-slate-400 text-sm leading-relaxed mb-6">
              {post.data.description}
            </p>
          </div>
          <div class="flex items-center justify-between border-t border-border-subtle/20 dark:border-slate-700 pt-6">
            <span class="text-secondary dark:text-slate-500 font-mono text-xs uppercase flex items-center gap-2">
              {post.data.readTime} {t.blog.min_read}
            </span>
            <a href={`/${lang === "es" ? "es/" : ""}blog/${post.slug}`}
              class="text-primary font-bold text-sm tracking-widest uppercase flex items-center gap-1 hover:gap-3 transition-all">
              Read
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
