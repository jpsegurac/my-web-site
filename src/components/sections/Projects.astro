---
import { getCollection } from "astro:content";
import { useTranslations } from "../../i18n";

interface Props { lang?: "en" | "es" }
const { lang = "en" } = Astro.props;
const t = useTranslations(lang);

const allProjects = await getCollection("projects");
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<section id="projects" class="py-24 px-8 bg-surface dark:bg-slate-950 clip-diagonal-top">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-16 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-4 h-4 bg-primary rotate-45"></div>
          <span class="font-mono text-xs text-primary uppercase tracking-widest font-bold">
            Selected Works
          </span>
        </div>
        <h2 class="text-5xl md:text-6xl font-headline font-black text-on-surface dark:text-slate-50 tracking-tighter">
          {t.projects.title}
        </h2>
        <div class="w-24 h-1.5 bg-primary mt-4"></div>
      </div>
      <p class="text-secondary dark:text-slate-400 max-w-md font-body">{t.projects.subtitle}</p>
    </div>

    <!-- Filter tabs -->
    <div class="flex flex-wrap gap-2 mb-12">
      {[t.projects.filter_all, t.projects.filter_web, t.projects.filter_mobile, t.projects.filter_api].map((label, i) => (
        <button
          class={`filter-btn font-label px-8 py-3 text-xs tracking-widest uppercase transition-all ${i === 0 ? "bg-primary text-white" : "bg-white dark:bg-slate-800 text-secondary dark:text-slate-400 border border-border-subtle/30 dark:border-slate-700 hover:bg-surface-container dark:hover:bg-slate-700"}`}
          data-filter={i === 0 ? "all" : label}
        >
          {label}
        </button>
      ))}
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((project, i) => {
        const shapes = ["triangle", "hexagon", "diamond"];
        const shape = shapes[i % 3];
        return (
          <div
            class="group relative bg-white dark:bg-slate-800 border-l-4 border-primary p-8 shadow-[0_20px_40px_rgba(15,23,42,0.06)] dark:shadow-none card-lift overflow-hidden"
            data-category={project.data.category}
          >
            <!-- Geometric watermark -->
            <div class="absolute -top-4 -right-4 opacity-[0.07] pointer-events-none">
              {shape === "triangle" && (
                <svg width="120" height="120" viewBox="0 0 100 100"><polygon points="50,5 95,95 5,95" fill="#4648d4"/></svg>
              )}
              {shape === "hexagon" && (
                <svg width="120" height="120" viewBox="0 0 100 100"><polygon points="50,0 93,25 93,75 50,100 7,75 7,25" fill="#4648d4"/></svg>
              )}
              {shape === "diamond" && (
                <svg width="120" height="120" viewBox="0 0 100 100"><polygon points="50,5 95,50 50,95 5,50" fill="#4648d4"/></svg>
              )}
            </div>

            <div class="relative z-10">
              <span class="font-mono text-[10px] text-secondary dark:text-slate-500 tracking-widest uppercase block mb-6">
                Case Study {String(i + 1).padStart(2, "0")}
              </span>
              <h3 class="text-xl font-headline font-bold text-on-surface dark:text-slate-50 tracking-tight mb-3 group-hover:text-primary transition-colors">
                {project.data.title}
              </h3>
              <p class="text-secondary dark:text-slate-400 text-sm leading-relaxed mb-8">
                {lang === "es" && project.data.descriptionEs
                  ? project.data.descriptionEs
                  : project.data.description}
              </p>

              <!-- Tags -->
              <div class="flex flex-wrap gap-2 mb-8">
                {project.data.tags.map((tag) => (
                  <span class="font-mono text-[10px] bg-surface-container dark:bg-slate-700 text-secondary dark:text-slate-400 px-2 py-1 uppercase">
                    {tag}
                  </span>
                ))}
              </div>

              <!-- Links -->
              <div class="flex items-center gap-6 border-t border-border-subtle/20 dark:border-slate-700 pt-6">
                {project.data.github && (
                  <a href={project.data.github} target="_blank" rel="noopener noreferrer"
                    class="flex items-center gap-1 text-primary font-label text-xs tracking-widest uppercase hover:underline">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.4.6.1.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.08-.74.08-.73.08-.73 1.2.09 1.83 1.23 1.83 1.23 1.07 1.83 2.8 1.3 3.48 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02 0 2.04.14 3 .4 2.28-1.55 3.29-1.23 3.29-1.23.64 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.21.69.82.57C20.57 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z"/></svg>
                    {t.projects.github}
                  </a>
                )}
                {project.data.live && (
                  <a href={project.data.live} target="_blank" rel="noopener noreferrer"
                    class="flex items-center gap-1 text-primary font-label text-xs tracking-widest uppercase hover:underline">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    {t.projects.live}
                  </a>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const cards = document.querySelectorAll<HTMLElement>("[data-category]");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter ?? "all";
      buttons.forEach((b) => b.classList.remove("bg-primary", "text-white"));
      btn.classList.add("bg-primary", "text-white");
      cards.forEach((card) => {
        const show = filter === "all" || card.dataset.category === filter;
        card.style.display = show ? "" : "none";
      });
    });
  });
</script>
